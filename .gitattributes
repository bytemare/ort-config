# Always use Unix line endings for Unix Gradle wrapper script.
gradlew	text eol=lf

# Always use Windows line endings for Windows batch scripts.
*.bat	text eol=crlf

# Keep our versions of these files during upstream merges.
# The "ours" merge driver is configured in the sync-upstream workflow
# (git config merge.ours.driver true) so that Git always resolves
# conflicts in these files by keeping the local (bytemare) version.
README.md merge=ours
.github/CODEOWNERS merge=ours
